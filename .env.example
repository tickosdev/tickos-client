# TickOS Client - Environment Variables
# Copy this file to .env.local and fill in your values

# ======================================
# REQUIRED: Session Secret
# ======================================

# Random string used to sign JWT session cookies
TICKOS_SESSION_SECRET=change-me-to-a-random-string

# ======================================
# OPTIONAL: Workspaces seed
# ======================================

# Workspaces are normally configured from the UI (setup wizard on first run,
# or Settings > Add workspace) and persisted in data/workspaces.json.
#
# You can optionally pre-seed workspaces via this env var (JSON array).
# Each API key belongs to exactly one workspace in tickos-core.
# TICKOS_WORKSPACES=[{"name":"My Workspace","url":"https://api.tickos.dev","key":"sk_xxx"}]
