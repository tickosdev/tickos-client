# TickOS Client - Environment Variables
# Copy this file to .env.local and fill in your values

# ======================================
# REQUIRED: API Configuration
# ======================================

# Your TickOS API Key (get it at https://app.tickos.dev/app/api-keys)
TICKOS_API_KEY=sk_your_api_key_here

# ======================================
# OPTIONAL: API URL
# ======================================

# Only change this if you're running a self-hosted TickOS instance
# Defaults to the production API
NEXT_PUBLIC_API_URL=https://api.tickos.dev
